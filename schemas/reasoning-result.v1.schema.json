{
  "$defs": {
    "CanonicalLiteral": {
      "additionalProperties": false,
      "properties": {
        "arguments": {
          "items": {
            "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$",
            "type": "string"
          },
          "maxItems": 2,
          "minItems": 1,
          "title": "Arguments",
          "type": "array"
        },
        "negated": {
          "title": "Negated",
          "type": "boolean"
        },
        "predicate": {
          "pattern": "^[a-z][a-z0-9_]{0,63}$",
          "title": "Predicate",
          "type": "string"
        }
      },
      "required": [
        "predicate",
        "arguments",
        "negated"
      ],
      "title": "CanonicalLiteral",
      "type": "object"
    },
    "DerivedLiteralNode": {
      "additionalProperties": false,
      "properties": {
        "depth": {
          "minimum": 1,
          "title": "Depth",
          "type": "integer"
        },
        "literal": {
          "$ref": "#/$defs/CanonicalLiteral"
        },
        "node_id": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Node Id",
          "type": "string"
        },
        "node_type": {
          "const": "derived_literal",
          "default": "derived_literal",
          "title": "Node Type",
          "type": "string"
        },
        "rule_application_node_id": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Rule Application Node Id",
          "type": "string"
        }
      },
      "required": [
        "node_id",
        "literal",
        "rule_application_node_id",
        "depth"
      ],
      "title": "DerivedLiteralNode",
      "type": "object"
    },
    "ProofDAG": {
      "additionalProperties": false,
      "properties": {
        "nodes": {
          "items": {
            "discriminator": {
              "mapping": {
                "derived_literal": "#/$defs/DerivedLiteralNode",
                "rule_application": "#/$defs/RuleApplicationNode",
                "source_fact": "#/$defs/SourceFactNode"
              },
              "propertyName": "node_type"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/SourceFactNode"
              },
              {
                "$ref": "#/$defs/RuleApplicationNode"
              },
              {
                "$ref": "#/$defs/DerivedLiteralNode"
              }
            ]
          },
          "maxItems": 100000,
          "title": "Nodes",
          "type": "array"
        },
        "opposition_root_id": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Opposition Root Id"
        },
        "proof_hash": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Proof Hash",
          "type": "string"
        },
        "query": {
          "$ref": "#/$defs/CanonicalLiteral"
        },
        "schema_version": {
          "const": "1.0",
          "default": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/ReasoningStatus"
        },
        "support_root_id": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Support Root Id"
        },
        "theory_hash": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Theory Hash",
          "type": "string"
        }
      },
      "required": [
        "theory_hash",
        "query",
        "status",
        "nodes",
        "proof_hash"
      ],
      "title": "ProofDAG",
      "type": "object"
    },
    "ReasoningLimitSnapshot": {
      "additionalProperties": false,
      "properties": {
        "max_derived_literals": {
          "exclusiveMinimum": 0,
          "title": "Max Derived Literals",
          "type": "integer"
        },
        "max_proof_nodes": {
          "exclusiveMinimum": 0,
          "title": "Max Proof Nodes",
          "type": "integer"
        },
        "max_rounds": {
          "exclusiveMinimum": 0,
          "title": "Max Rounds",
          "type": "integer"
        },
        "max_rule_firings": {
          "exclusiveMinimum": 0,
          "title": "Max Rule Firings",
          "type": "integer"
        },
        "timeout_seconds": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timeout Seconds"
        }
      },
      "required": [
        "max_derived_literals",
        "max_rule_firings",
        "max_rounds",
        "max_proof_nodes"
      ],
      "title": "ReasoningLimitSnapshot",
      "type": "object"
    },
    "ReasoningResult": {
      "additionalProperties": false,
      "properties": {
        "closure_contains_conflicts": {
          "title": "Closure Contains Conflicts",
          "type": "boolean"
        },
        "conflict_count": {
          "minimum": 0,
          "title": "Conflict Count",
          "type": "integer"
        },
        "proof": {
          "$ref": "#/$defs/ProofDAG"
        },
        "query": {
          "$ref": "#/$defs/CanonicalLiteral"
        },
        "schema_version": {
          "const": "1.0",
          "default": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/ReasoningStatus"
        },
        "theory_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$",
          "title": "Theory Id",
          "type": "string"
        }
      },
      "required": [
        "theory_id",
        "status",
        "query",
        "closure_contains_conflicts",
        "conflict_count",
        "proof"
      ],
      "title": "ReasoningResult",
      "type": "object"
    },
    "ReasoningStatus": {
      "enum": [
        "ENTAILED",
        "CONTRADICTED",
        "UNKNOWN",
        "INCONSISTENT"
      ],
      "title": "ReasoningStatus",
      "type": "string"
    },
    "ReasoningTelemetry": {
      "additionalProperties": false,
      "properties": {
        "conflict_count": {
          "minimum": 0,
          "title": "Conflict Count",
          "type": "integer"
        },
        "derived_fact_count": {
          "minimum": 0,
          "title": "Derived Fact Count",
          "type": "integer"
        },
        "duplicate_conclusions": {
          "minimum": 0,
          "title": "Duplicate Conclusions",
          "type": "integer"
        },
        "execution_duration_ms": {
          "minimum": 0,
          "title": "Execution Duration Ms",
          "type": "number"
        },
        "initial_fact_count": {
          "minimum": 0,
          "title": "Initial Fact Count",
          "type": "integer"
        },
        "maximum_proof_depth": {
          "minimum": 0,
          "title": "Maximum Proof Depth",
          "type": "integer"
        },
        "resource_limits": {
          "$ref": "#/$defs/ReasoningLimitSnapshot"
        },
        "rounds": {
          "minimum": 0,
          "title": "Rounds",
          "type": "integer"
        },
        "rule_instances_considered": {
          "minimum": 0,
          "title": "Rule Instances Considered",
          "type": "integer"
        },
        "successful_rule_firings": {
          "minimum": 0,
          "title": "Successful Rule Firings",
          "type": "integer"
        },
        "total_closure_size": {
          "minimum": 0,
          "title": "Total Closure Size",
          "type": "integer"
        }
      },
      "required": [
        "initial_fact_count",
        "derived_fact_count",
        "total_closure_size",
        "conflict_count",
        "rounds",
        "rule_instances_considered",
        "successful_rule_firings",
        "duplicate_conclusions",
        "maximum_proof_depth",
        "execution_duration_ms",
        "resource_limits"
      ],
      "title": "ReasoningTelemetry",
      "type": "object"
    },
    "RuleApplicationNode": {
      "additionalProperties": false,
      "properties": {
        "conclusion": {
          "$ref": "#/$defs/CanonicalLiteral"
        },
        "depth": {
          "minimum": 1,
          "title": "Depth",
          "type": "integer"
        },
        "node_id": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Node Id",
          "type": "string"
        },
        "node_type": {
          "const": "rule_application",
          "default": "rule_application",
          "title": "Node Type",
          "type": "string"
        },
        "premise_node_ids": {
          "items": {
            "type": "string"
          },
          "maxItems": 64,
          "minItems": 1,
          "title": "Premise Node Ids",
          "type": "array"
        },
        "rule_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$",
          "title": "Rule Id",
          "type": "string"
        },
        "source_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$",
          "title": "Source Id",
          "type": "string"
        },
        "source_text": {
          "maxLength": 10000,
          "minLength": 1,
          "title": "Source Text",
          "type": "string"
        },
        "substitution": {
          "items": {
            "$ref": "#/$defs/SubstitutionBinding"
          },
          "maxItems": 64,
          "title": "Substitution",
          "type": "array"
        }
      },
      "required": [
        "node_id",
        "rule_id",
        "source_id",
        "source_text",
        "substitution",
        "premise_node_ids",
        "conclusion",
        "depth"
      ],
      "title": "RuleApplicationNode",
      "type": "object"
    },
    "SourceFactNode": {
      "additionalProperties": false,
      "properties": {
        "depth": {
          "const": 0,
          "default": 0,
          "title": "Depth",
          "type": "integer"
        },
        "literal": {
          "$ref": "#/$defs/CanonicalLiteral"
        },
        "node_id": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Node Id",
          "type": "string"
        },
        "node_type": {
          "const": "source_fact",
          "default": "source_fact",
          "title": "Node Type",
          "type": "string"
        },
        "source_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$",
          "title": "Source Id",
          "type": "string"
        },
        "source_text": {
          "maxLength": 10000,
          "minLength": 1,
          "title": "Source Text",
          "type": "string"
        }
      },
      "required": [
        "node_id",
        "literal",
        "source_id",
        "source_text"
      ],
      "title": "SourceFactNode",
      "type": "object"
    },
    "SubstitutionBinding": {
      "additionalProperties": false,
      "properties": {
        "entity": {
          "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$",
          "title": "Entity",
          "type": "string"
        },
        "variable": {
          "pattern": "^[A-Z][A-Za-z0-9_]{0,63}$",
          "title": "Variable",
          "type": "string"
        }
      },
      "required": [
        "variable",
        "entity"
      ],
      "title": "SubstitutionBinding",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "result": {
      "$ref": "#/$defs/ReasoningResult"
    },
    "telemetry": {
      "$ref": "#/$defs/ReasoningTelemetry"
    }
  },
  "required": [
    "result",
    "telemetry"
  ],
  "title": "ReasoningOutput",
  "type": "object"
}
