# Docker Compose ports and browser-visible backend URL. These are not secrets.
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
VERILOGIC_CORS_ORIGINS=["http://localhost:3000"]
# Optional Phase 3 provider secret. Leave empty here; set only in a local ignored
# environment or secret manager. Its presence alone never authorizes an API call.
OPENAI_API_KEY=
